[run]
source = src
omit =
    src/backtesting__backtest.py
    src/dashboard__streamlit_dashboard.py
    src/evaluation__evaluate_model.py
    src/market_data/downloader.py
    src/market_data/provider.py
    src/market_data/service.py
    src/market_data/updater.py
    src/market_data/update_scheduler.py
    src/prediction__predict_core.py
    src/prediction__predict_model.py
    src/training__train_core.py
    src/training__train_model.py

[report]
show_missing = True
exclude_lines =
    pragma: no cover
    if __name__ == .__main__.:
